# RELAI simulator environment template for the SkyServe airline support agent.
# Copy to .relai/simulator.env and fill in real values. Do not commit secrets.
# Set at least one model provider key.

# OpenAI Agents SDK default model path.
OPENAI_API_KEY=

# Optional fallback: LiteLLM Anthropic model when OPENAI_API_KEY is not set.
ANTHROPIC_API_KEY=
